hardstatus alwaysignore 
caption always "%{= kG}[ %S %> | %> %{= kw}%-w%{+ kr}%n*%t%?(%u)%? %{-}%+w %{= kG} %= %?%E%{+s}%?%w]"


# 256 colors
attrcolor b ".I"
termcapinfo xterm 'Co#256:AB=\E[48;5;%dm:AF=\E[38;5;%dm'
defbce on

# mouse tracking allows to switch region focus by clicking
mousetrack on

# for vim background issue 
altscreen on

bind s split 
